                    outerLoop:
                    for (let pixel = 0; pixel < totalPixels; pixel++) {
                        const base = pixel * 4;
                        for (let seqIdx = 0; seqIdx < seqLen; seqIdx++) {
                            const { channelIdx, bitPos } = embedSequence[seqIdx];
                            if (globalSlot >= offsetBits) {
                                const pixelValue = imageData[base + channelIdx];
                                const bit = (pixelValue >> bitPos) & 1;
                                if (bit === 1) bitBuffer |= (1 << bitCount);
                                bitCount++;
                                if (bitCount === 8) {
                                    byteBuffer.push(bitBuffer);
                                    totalBytesSent++;
                                    if (totalBytesSent >= maxBytesLimit) {
                                        stopFlag = true;
                                        if (byteBuffer.length > 0) {
                                            self.postMessage({ type: 'chunk', data: new Uint8Array(byteBuffer) });
                                            byteBuffer = [];
                                        }
                                        break outerLoop;
                                    }
                                    bitBuffer = 0;
                                    bitCount = 0;
                                    if (byteBuffer.length >= targetChunkBytes) {
                                        self.postMessage({ type: 'chunk', data: new Uint8Array(byteBuffer) });
                                        byteBuffer = [];
                                    }
                                }
                            }
                            globalSlot++;
                            if (globalSlot % 200000 === 0 && !stopFlag) {
                                const progressPercent = (globalSlot / totalSlots) * 100;
                                if (progressPercent - lastProgress >= 2) {
                                    lastProgress = progressPercent;
                                    self.postMessage({ type: 'progress', percent: progressPercent, text: \`提取中... \${Math.round(progressPercent)}% (\${globalSlot.toLocaleString()}/\${totalSlots.toLocaleString()} slots)\` });
                                }
                            }
                        }
                        if (stopFlag) break;
                    }
                    if (!stopFlag && byteBuffer.length > 0) {
                        self.postMessage({ type: 'chunk', data: new Uint8Array(byteBuffer) });
                    }
                    self.postMessage({ type: 'complete', totalBytes: totalBytesSent, reachedLimit: stopFlag });
                } catch(err) {
                    self.postMessage({ type: 'error', message: err.message });
                }
            };
        `;
        const blob = new Blob([workerCode], { type: 'application/javascript' });
        return new Worker(URL.createObjectURL(blob));
    }
    
    async function performExtract() {
        if (!currentImageData) {
            setInfo("请先上传含隐写信息的图像", true);
            return;
        }
        if (embedSequence.length === 0) {
            setInfo("请先通过复选框定义嵌入顺序 (必须与嵌入时完全一致)", true);
            return;
        }
        const offset = parseInt(extractOffset.value, 10);
        if (isNaN(offset) || offset < 0) {
            setInfo("偏移量无效", true);
            return;
        }
        
        let maxBytes = parseInt(maxExtractBytesInput.value, 10);
        if (isNaN(maxBytes) || maxBytes < 0) maxBytes = 0;
        if (maxBytes > MAX_EXTRACT_BYTES) {
            setInfo(`提取字节数不能超过 ${MAX_EXTRACT_BYTES/1024/1024}MB，已自动限制`, true);
            maxBytes = MAX_EXTRACT_BYTES;
            maxExtractBytesInput.value = maxBytes;
        }
        
        const totalPixels = currentWidth * currentHeight;
        const maxSlots = totalPixels * embedSequence.length;
        if (offset > maxSlots) {
            setInfo(`偏移量 ${offset} 超过最大槽位数 ${maxSlots.toLocaleString()}，无法提取任何数据`, true);
            return;
        }
        
        accumulatedChunks = [];
        totalExtractedBytes = 0;
        extractedBytes = null;
        resultArea.style.display = 'none';
        extractLimitStatus.innerText = '';
        
        if (worker) worker.terminate();
        const CHUNK_SIZE_BYTES = 1024 * 1024;  // 1MB chunk
        worker = createChunkedExtractWorker();
        
        showProgress(true, 0, "分块提取启动...");
        setInfo(`⏳ 分块提取中，顺序长度 ${embedSequence.length}, 偏移 ${offset}, 最大提取字节 ${maxBytes === 0 ? '全部' : maxBytes.toLocaleString()}`);
        
        return new Promise((resolve, reject) => {
            let isResolved = false;
            let reachedLimitFlag = false;
            worker.onmessage = (msgEv) => {
                const msg = msgEv.data;
                if (msg.type === 'progress') {
                    extractProgress.style.width = `${msg.percent}%`;
                    progressText.innerText = msg.text;
                } else if (msg.type === 'chunk') {
                    const chunkBytes = msg.data;
                    if (chunkBytes && chunkBytes.length > 0) {
                        totalExtractedBytes += chunkBytes.length;
                        if (totalExtractedBytes > MAX_EXTRACT_BYTES) {
                            worker.terminate();
                            worker = null;
                            showProgress(false);
                            setInfo(`❌ 提取数据超过限制 (${MAX_EXTRACT_BYTES/1024/1024}MB)，可能顺序或偏移量有误`, true);
                            reject(new Error("超出最大提取限制"));
                            return;
                        }
                        accumulatedChunks.push(chunkBytes);
                        progressText.innerText = `已提取 ${totalExtractedBytes.toLocaleString()} 字节...`;
                    }
                } else if (msg.type === 'complete') {
                    if (isResolved) return;
                    isResolved = true;
                    reachedLimitFlag = msg.reachedLimit === true;
                    try {
                        if (accumulatedChunks.length === 0 && totalExtractedBytes === 0) {
                            throw new Error("未提取到任何数据，请检查偏移量或顺序是否正确");
                        }
                        const totalLength = accumulatedChunks.reduce((sum, arr) => sum + arr.length, 0);
                        const finalBytes = new Uint8Array(totalLength);
                        let pos = 0;
                        for (const chunk of accumulatedChunks) {
                            finalBytes.set(chunk, pos);
                            pos += chunk.length;
                        }
                        extractedBytes = finalBytes;
                        showProgress(false);
                        resultArea.style.display = 'block';
                        extractedSizeSpan.innerText = extractedBytes.length.toLocaleString();
                        
                        if (maxBytes > 0 && extractedBytes.length >= maxBytes && reachedLimitFlag) {
                            extractLimitStatus.innerText = `(已达到指定限制 ${maxBytes.toLocaleString()} 字节)`;
                        } else if (maxBytes > 0 && extractedBytes.length < maxBytes) {
                            extractLimitStatus.innerText = `(实际可用数据不足，共提取全部可用 ${extractedBytes.length.toLocaleString()} 字节)`;
                        } else {
                            extractLimitStatus.innerText = `(全部可用数据)`;
                        }
                        
                        displayExtractedData(extractedBytes, reachedLimitFlag, maxBytes);
                        setInfo(`✅ 提取完成！共提取 ${extractedBytes.length.toLocaleString()} 字节。${(maxBytes>0 && extractedBytes.length>=maxBytes && reachedLimitFlag) ? `已达到用户设定的 ${maxBytes.toLocaleString()} 字节限制。` : ''}`);
                        resolve(true);
                    } catch(err) {
                        showProgress(false);
                        reject(new Error(`合并数据失败: ${err.message}`));
                    } finally {
                        worker.terminate();
                        worker = null;
                    }
                } else if (msg.type === 'error') {
                    if (isResolved) return;
                    isResolved = true;
                    showProgress(false);
                    reject(new Error(msg.message));
                    worker.terminate();
                    worker = null;
                }
            };
            worker.onerror = (err) => {
                if (isResolved) return;
                isResolved = true;
                showProgress(false);
                reject(new Error("Worker内部错误: " + err.message));
                worker.terminate();
                worker = null;
            };
            const imageDataArray = currentImageData.data.slice();
            worker.postMessage({
                imageData: imageDataArray,
                embedSequence: embedSequence,
                offsetBits: offset,
                width: currentWidth,
                height: currentHeight,
                chunkByteSize: CHUNK_SIZE_BYTES,
                maxExtractBytes: maxBytes
            }, [imageDataArray.buffer]);
        });
    }
    
    function displayExtractedData(dataBytes, isLimitReached, maxLimitBytes) {
        if (!dataBytes || dataBytes.length === 0) {
            binaryResultDiv.innerHTML = '<pre>—</pre>';
            hexResultDiv.innerHTML = '<pre>—</pre>';
            utf8ResultDiv.innerHTML = '<pre>—</pre>';
            truncationWarningDiv.style.display = 'none';
            afterExtractStoreLines();
            return;
        }
        let previewBytes = dataBytes;
        let isTruncated = false;
        if (dataBytes.length > MAX_PREVIEW_BYTES) {
            previewBytes = dataBytes.slice(0, MAX_PREVIEW_BYTES);
            isTruncated = true;
        }
        const binaryStr = formatBinaryFull(previewBytes);
        const hexStr = formatHexFull(previewBytes);
        const utf8Str = formatUtf8WithOffset(previewBytes, 16);
        binaryResultDiv.innerHTML = `<pre>${escapeHtml(binaryStr)}</pre>`;
        hexResultDiv.innerHTML = `<pre>${escapeHtml(hexStr)}</pre>`;
        utf8ResultDiv.innerHTML = `<pre>${escapeHtml(utf8Str)}</pre>`;
        
        if (isTruncated) {
            truncationWarningDiv.style.display = 'block';
            truncationWarningDiv.innerHTML = `⚠️ 提取数据共 ${dataBytes.length.toLocaleString()} 字节，预览仅显示前 ${MAX_PREVIEW_BYTES.toLocaleString()} 字节。完整数据可点击“保存为文件”下载。`;
        } else {
            truncationWarningDiv.style.display = 'none';
        }
        afterExtractStoreLines();
    }
    
    async function onExtractClick() {
        try {
            extractBtn.disabled = true;
            await performExtract();
        } catch(err) {
            setInfo(`提取失败: ${err.message}`, true);
            resultArea.style.display = 'none';
            extractedBytes = null;
        } finally {
            extractBtn.disabled = false;
        }
    }
    
    function saveExtractedAsFile() {
        if (!extractedBytes || extractedBytes.length === 0) {
            setInfo("没有可保存的数据，请先提取", true);
            return;
        }
        const blob = new Blob([extractedBytes], { type: 'application/octet-stream' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = "extracted_data.bin";
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
        setInfo(`文件已下载: extracted_data.bin (${extractedBytes.length.toLocaleString()} 字节)`);
    }
    
    async function onImageSelected(file) {
        if (!file) return;
        updatePreview(file);
        try {
            const { imageData, width, height } = await loadImageToImageData(file);
            currentImageData = imageData;
            currentWidth = width;
            currentHeight = height;
            setInfo(`图像加载成功: ${width}x${height}, 总像素 ${(width*height).toLocaleString()}`);
            updateCapacityDisplay();
            resultArea.style.display = 'none';
            extractedBytes = null;
            accumulatedChunks = [];
            clearAllHighlights();
        } catch(err) {
            setInfo(`图像加载失败: ${err.message}`, true);
            currentImageData = null;
            imgPreviewContainer.innerHTML = '';
            resultArea.style.display = 'none';
            loadModeInfo.innerHTML = "❌ 加载失败，请重试或更换图像";
        }
    }
    
    function initPixelRows() {
        pixelRows = [0];
        rebuildPixelTable();
    }
    
    // 事件绑定
    stegoImageUpload.addEventListener('change', (e) => { if(e.target.files[0]) onImageSelected(e.target.files[0]); });
    extractBtn.addEventListener('click', onExtractClick);
    addPixelRowBtn.addEventListener('click', addPixelRow);
    resetOrderBtn.addEventListener('click', resetSequence);
    saveAsFileBtn.addEventListener('click', saveExtractedAsFile);
    extractOffset.addEventListener('input', () => {
        resultArea.style.display = 'none';
        extractedBytes = null;
        setInfo("偏移量已更改，请重新提取");
        clearAllHighlights();
    });
    maxExtractBytesInput.addEventListener('input', () => {
        resultArea.style.display = 'none';
        extractedBytes = null;
        setInfo("最大提取字节数已更改，请重新提取");
        clearAllHighlights();
    });
    
    // 查找事件绑定
    searchBtn.addEventListener('click', performSearch);
    clearHighlightBtn.addEventListener('click', () => { clearAllHighlights(); setInfo("已清除高亮", false); });
    prevMatchBtn.addEventListener('click', prevMatch);
    nextMatchBtn.addEventListener('click', nextMatch);
    
    initPixelRows();
    setInfo("就绪，请上传图像并定义与嵌入时完全相同的顺序和偏移量，支持限制提取字节数（0表示全部）。提取后自动展示二进制/十六进制/UTF-8预览，支持内容查找高亮。");
})();
</script>
